classDiagram
    class Owner {
        +str name
        +list pets
        +list tasks
        +addPet(pet: Pet) None
        +addTask(task: Task) None
    }

    class Pet {
        +str name
        +str species
    }

    class Task {
        +str name
        +int duration
        +str priority
        +bool is_complete
        +markDone() None
    }

    class Scheduler {
        +list tasks
        +list daily_plan
        +buildPlan() list
        +displayPlan() str
    }

    Owner "1" --> "1..*" Pet : owns
    Owner "1" --> "0..*" Task : manages
    Scheduler "1" --> "0..*" Task : schedules
